{
  "extends": "astro/tsconfigs/base",
  "include": [
    "src/**/*",
    "./worker-configuration.d.ts"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@scripts/*": [
        "./src/scripts/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ]
    }
  }
}